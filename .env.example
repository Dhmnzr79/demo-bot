# Set to 1 for emergency fallback to v4 logic (classify_intent only); default 0 keeps Resolver on.
RESOLVER_OFF=0

# Multiclient (локалка и VPS). Индекс и SQLite — в data/{client_id}/.
ALLOWED_CLIENTS=demo,cesi,nikadent
DEFAULT_CLIENT_ID=demo

# PostgreSQL для admin_dashboard (Phase M4). Локально: docker compose up -d postgres
BOT_PG_DSN=postgresql://bot:bot@localhost:5432/bot_events

# Оценка стоимости LLM в admin (USD за 1M токенов). 0 = не считать USD.
# gpt-5.4-nano: 0.20 / 1.25 · gpt-5.4-mini: 0.75 / 4.50 (openai.com/api/pricing)
BOT_LLM_USD_PER_1M_PROMPT=0.49
BOT_LLM_USD_PER_1M_COMPLETION=3.00

# SMTP — отправка заявок (cesi / nikadent). Секреты только здесь, не в git.
# Получатели писем — в clients/{id}/lead_config.yaml → recipients
SMTP_HOST=mail.artgents.ru
SMTP_PORT=465
SMTP_USE_SSL=1
SMTP_USE_TLS=0
SMTP_USER=bot@artgents.ru
SMTP_PASSWORD=
SMTP_FROM=bot@artgents.ru
