# Set to 1 for emergency fallback to v4 logic (classify_intent only); default 0 keeps Resolver on.
RESOLVER_OFF=0

# Multiclient (локалка и VPS). Пока индекс общий — retrieval для demo/cesi/nikadent
# идёт через effective_corpus_client_id → default, пока нет data/{id}/corpus.jsonl.
ALLOWED_CLIENTS=default,demo,cesi,nikadent
DEFAULT_CLIENT_ID=default

# PostgreSQL для admin_dashboard (Phase M4). Пример:
# BOT_PG_DSN=postgresql://bot:bot@localhost:5432/bot_events
